# Root .gitignore for NOCTA Monorepo

# Dependencies
**/node_modules/

# Environment Variables
**/.env
**/.env.local
**/.env.production
**/.env.development.local
**/.env.test.local
**/.env.production.local

# Next.js build
frontend/.next/
frontend/out/

# Backend uploads
backend/uploads/

# OS files
.DS_Store
Thumbs.db

# Debug logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
